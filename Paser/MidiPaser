using System.Text;
using MidiConverter.Models;

namespace MidiConverter.Parsers;

/// <summary>
/// 纯C#实现的MIDI文件解析器
/// 不依赖任何外部库，支持MIDI格式0和1的读写
/// </summary>
public class MidiParser
{
    /// <summary>
    /// MIDI文件头魔数（"MThd"）
    /// </summary>
    private const uint MIDI_HEADER_MAGIC = 0x4D546864;

    /// <summary>
    /// MIDI轨道魔数（"MTrk"）
    /// </summary>
    private const uint MIDI_TRACK_MAGIC = 0x4D54726B;

    /// <summary>
    /// 默认Ticks Per Quarter（当时分值无效时使用）
    /// </summary>
    private const int DEFAULT_TICKS_PER_QUARTER = 480;

    /// <summary>
    /// 从文件解析MIDI
    /// </summary>
    /// <param name="filePath">MIDI文件路径</param>
    /// <returns>MIDI文件对象</returns>
    public MidiFile ParseFile(string filePath)
    {
        using var stream = new FileStream(filePath, FileMode.Open, FileAccess.Read);
        return Parse(stream);
    }

    /// <summary>
    /// 从字节数组解析MIDI
    /// </summary>
    /// <param name="data">MIDI数据</param>
    /// <returns>MIDI文件对象</returns>
    public MidiFile Parse(byte[] data)
    {
        using var stream = new MemoryStream(data);
        return Parse(stream);
    }

    /// <summary>
    /// 从流解析MIDI
    /// </summary>
    /// <param name="stream">数据流</param>
    /// <returns>MIDI文件对象</returns>
    public MidiFile Parse(Stream stream)
    {
        using var reader = new BinaryReader(stream);
        var midiFile = new MidiFile();
        midiFile.Header = ReadHeader(reader);

        // 读取所有轨道
        for (int i = 0; i < midiFile.Header.TrackCount; i++)
        {
            var track = ReadTrack(reader);
            midiFile.Tracks.Add(track);
        }

        return midiFile;
    }

    /// <summary>
    /// 读取MIDI文件头
    /// </summary>
    /// <param name="reader">二进制读取器</param>
    /// <returns>MIDI文件头</returns>
    /// <exception cref="InvalidDataException">文件格式无效时抛出</exception>
    private MidiHeader ReadHeader(BinaryReader reader)
    {
        var header = new MidiHeader();
        
        // 验证魔数
        var magic = reader.ReadUInt32BigEndian();
        if (magic != MIDI_HEADER_MAGIC)
            throw new InvalidDataException($"无效的MIDI文件头，期望MThd，实际: 0x{magic:X8}");

        // 头部长度必须为6
        var headerLength = reader.ReadUInt32BigEndian();
        if (headerLength != 6)
            throw new InvalidDataException($"无效的MIDI头部长度: {headerLength}，期望: 6");

        header.Format = reader.ReadUInt16BigEndian();
        header.TrackCount = reader.ReadUInt16BigEndian();
        header.Division = reader.ReadUInt16BigEndian();
        
        return header;
    }

    /// <summary>
    /// 读取单个轨道
    /// </summary>
    /// <param name="reader">二进制读取器</param>
    /// <returns>MIDI轨道</returns>
    private MidiTrack ReadTrack(BinaryReader reader)
    {
        var track = new MidiTrack();
        
        // 验证轨道魔数
        var magic = reader.ReadUInt32BigEndian();
        if (magic != MIDI_TRACK_MAGIC)
            throw new InvalidDataException($"无效的MIDI轨道头，期望MTrk，实际: 0x{magic:X8}");

        var trackLength = reader.ReadUInt32BigEndian();
        var trackEndPosition = reader.BaseStream.Position + trackLength;
        
        byte runningStatus = 0;  // 运行状态字节（用于压缩）
        long absoluteTime = 0;    // 累计绝对时间

        while (reader.BaseStream.Position < trackEndPosition)
        {
            // 读取可变长度数量（Delta Time）
            var deltaTime = ReadVariableLengthQuantity(reader);
            absoluteTime += deltaTime;
            
            byte statusByte = reader.ReadByte();

            // 处理运行状态（状态字节最高位为0表示使用上一个状态）
            if ((statusByte & 0x80) == 0)
            {
                reader.BaseStream.Position--;  // 回退一个字节
                statusByte = runningStatus;
            }
            else
            {
                runningStatus = statusByte;
            }

            var evt = new MidiEvent
            {
                DeltaTime = deltaTime,
                AbsoluteTime = absoluteTime
            };

            // 解析事件
            ParseEvent(reader, evt, statusByte);
            track.Events.Add(evt);
        }

        return track;
    }

    /// <summary>
    /// 解析单个MIDI事件
    /// </summary>
    private void ParseEvent(BinaryReader reader, MidiEvent evt, byte statusByte)
    {
        // 元事件（0xFF）
        if (statusByte == 0xFF)
        {
            evt.Type = MidiEventType.Meta;
            evt.MetaType = reader.ReadByte();
            var metaLength = ReadVariableLengthQuantity(reader);
            evt.MetaData = reader.ReadBytes((int)metaLength);
        }
        // 系统独占事件（0xF0或0xF7）
        else if (statusByte == 0xF0 || statusByte == 0xF7)
        {
            evt.Type = MidiEventType.SysEx;
            var sysExLength = ReadVariableLengthQuantity(reader);
            evt.Data = reader.ReadBytes((int)sysExLength);
        }
        else
        {
            // MIDI通道事件
            byte eventType = (byte)((statusByte >> 4) & 0x0F);
            evt.Channel = (byte)(statusByte & 0x0F);

            switch (eventType)
            {
                case 0x08:
                    evt.Type = MidiEventType.NoteOff;
                    evt.Note = reader.ReadByte();
                    evt.Velocity = reader.ReadByte();
                    break;
                case 0x09:
                    evt.Type = MidiEventType.NoteOn;
                    evt.Note = reader.ReadByte();
                    evt.Velocity = reader.ReadByte();
                    break;
                case 0x0A:
                    evt.Type = MidiEventType.KeyAfterTouch;
                    evt.Note = reader.ReadByte();
                    evt.Velocity = reader.ReadByte();
                    break;
                case 0x0B:
                    evt.Type = MidiEventType.ControlChange;
                    evt.ControllerNumber = reader.ReadByte();
                    evt.ControllerValue = reader.ReadByte();
                    break;
                case 0x0C:
                    evt.Type = MidiEventType.ProgramChange;
                    evt.ProgramNumber = reader.ReadByte();
                    break;
                case 0x0D:
                    evt.Type = MidiEventType.ChannelAfterTouch;
                    evt.Velocity = reader.ReadByte();
                    break;
                case 0x0E:
                    evt.Type = MidiEventType.PitchBend;
                    byte lsb = reader.ReadByte();  // 低7位
                    byte msb = reader.ReadByte();  // 高7位
                    // 弯音值 = (msb << 7) | lsb，范围0-16383，8192为中心（无弯音）
                    break;
                default:
                    evt.Type = MidiEventType.Unknown;
                    break;
            }
        }
    }

    /// <summary>
    /// 读取可变长度数量（Variable Length Quantity）
    /// MIDI标准压缩格式，每个字节最高位为1表示后续还有字节
    /// </summary>
    /// <param name="reader">二进制读取器</param>
    /// <returns>解码后的整数值</returns>
    private long ReadVariableLengthQuantity(BinaryReader reader)
    {
        long value = 0;
        byte b;
        do
        {
            b = reader.ReadByte();
            value = (value << 7) | (b & 0x7F);  // 取低7位
        } while ((b & 0x80) != 0);  // 最高位为1则继续
        return value;
    }

    /// <summary>
    /// 写入可变长度数量
    /// </summary>
    private void WriteVariableLengthQuantity(BinaryWriter writer, long value)
    {
        var bytes = new List<byte>();
        do
        {
            bytes.Insert(0, (byte)(value & 0x7F));
            value >>= 7;
        } while (value > 0);

        // 除最后一个字节外，其余最高位置1
        for (int i = 0; i < bytes.Count - 1; i++)
            bytes[i] |= 0x80;

        writer.Write(bytes.ToArray());
    }

    /// <summary>
    /// 将MIDI文件写入流
    /// </summary>
    public void Write(MidiFile midiFile, Stream stream)
    {
        using var writer = new BinaryWriter(stream);
        WriteHeader(writer, midiFile.Header);
        
        foreach (var track in midiFile.Tracks)
            WriteTrack(writer, track);
    }

    /// <summary>
    /// 将MIDI文件写入文件
    /// </summary>
    public void WriteToFile(MidiFile midiFile, string filePath)
    {
        using var stream = new FileStream(filePath, FileMode.Create, FileAccess.Write);
        Write(midiFile, stream);
    }

    /// <summary>
    /// 写入MIDI文件头
    /// </summary>
    private void WriteHeader(BinaryWriter writer, MidiHeader header)
    {
        writer.WriteUInt32BigEndian(MIDI_HEADER_MAGIC);
        writer.WriteUInt32BigEndian(6);  // 头部长度固定为6
        writer.WriteUInt16BigEndian(header.Format);
        writer.WriteUInt16BigEndian(header.TrackCount);
        writer.WriteUInt16BigEndian(header.Division);
    }

    /// <summary>
    /// 写入单个轨道
    /// </summary>
    private void WriteTrack(BinaryWriter writer, MidiTrack track)
    {
        using var trackStream = new MemoryStream();
        using var trackWriter = new BinaryWriter(trackStream);
        
        byte runningStatus = 0;
        
        foreach (var evt in track.Events)
        {
            WriteVariableLengthQuantity(trackWriter, evt.DeltaTime);
            
            if (evt.Type == MidiEventType.Meta)
            {
                // 元事件：0xFF + 类型 + 长度 + 数据
                trackWriter.Write((byte)0xFF);
                trackWriter.Write((byte)evt.MetaType);
                WriteVariableLengthQuantity(trackWriter, evt.MetaData.Length);
                trackWriter.Write(evt.MetaData);
                runningStatus = 0;
            }
            else if (evt.Type == MidiEventType.SysEx)
            {
                // 系统独占事件
                trackWriter.Write((byte)0xF0);
                WriteVariableLengthQuantity(trackWriter, evt.Data.Length);
                trackWriter.Write(evt.Data);
                runningStatus = 0;
            }
            else
            {
                // 构建状态字节（0x8n - 0xEn）
                byte statusByte = evt.Type switch
                {
                    MidiEventType.NoteOff => (byte)(0x80 | evt.Channel),
                    MidiEventType.NoteOn => (byte)(0x90 | evt.Channel),
                    MidiEventType.KeyAfterTouch => (byte)(0xA0 | evt.Channel),
                    MidiEventType.ControlChange => (byte)(0xB0 | evt.Channel),
                    MidiEventType.ProgramChange => (byte)(0xC0 | evt.Channel),
                    MidiEventType.ChannelAfterTouch => (byte)(0xD0 | evt.Channel),
                    MidiEventType.PitchBend => (byte)(0xE0 | evt.Channel),
                    _ => (byte)(0x80 | evt.Channel)
                };
                
                // 运行状态优化（如果状态相同则省略）
                if (statusByte != runningStatus)
                {
                    trackWriter.Write(statusByte);
                    runningStatus = statusByte;
                }
                
                // 写入事件特定数据
                WriteEventData(trackWriter, evt);
            }
        }
        
        // 写入轨道头和长度
        writer.WriteUInt32BigEndian(MIDI_TRACK_MAGIC);
        writer.WriteUInt32BigEndian((uint)trackStream.Length);
        
        trackStream.Position = 0;
        trackStream.CopyTo(writer.BaseStream);
    }

    /// <summary>
    /// 写入MIDI事件的数据部分（不包括状态字节和DeltaTime）
    /// </summary>
    private void WriteEventData(BinaryWriter writer, MidiEvent evt)
    {
        switch (evt.Type)
        {
            case MidiEventType.NoteOff:
            case MidiEventType.NoteOn:
                writer.Write(evt.Note);
                writer.Write(evt.Velocity);
                break;
            case MidiEventType.KeyAfterTouch:
                writer.Write(evt.Note);
                writer.Write(evt.Velocity);
                break;
            case MidiEventType.ControlChange:
                writer.Write(evt.ControllerNumber);
                writer.Write(evt.ControllerValue);
                break;
            case MidiEventType.ProgramChange:
                writer.Write(evt.ProgramNumber);
                break;
            case MidiEventType.ChannelAfterTouch:
                writer.Write(evt.Velocity);
                break;
            case MidiEventType.PitchBend:
                // 弯音值：低7位 + 高7位
                writer.Write((byte)0);    // LSB
                writer.Write((byte)64);   // MSB（中心位置）
                break;
        }
    }
}

/// <summary>
/// BinaryReader扩展方法
/// 提供大端序（Big Endian）读写支持（MIDI标准使用大端序）
/// </summary>
public static class BinaryReaderExtensions
{
    /// <summary>
    /// 读取大端序UInt16
    /// </summary>
    public static ushort ReadUInt16BigEndian(this BinaryReader reader)
    {
        var bytes = reader.ReadBytes(2);
        if (BitConverter.IsLittleEndian) Array.Reverse(bytes);
        return BitConverter.ToUInt16(bytes, 0);
    }

    /// <summary>
    /// 读取大端序UInt32
    /// </summary>
    public static uint ReadUInt32BigEndian(this BinaryReader reader)
    {
        var bytes = reader.ReadBytes(4);
        if (BitConverter.IsLittleEndian) Array.Reverse(bytes);
        return BitConverter.ToUInt32(bytes, 0);
    }

    /// <summary>
    /// 写入大端序UInt16
    /// </summary>
    public static void WriteUInt16BigEndian(this BinaryWriter writer, ushort value)
    {
        var bytes = BitConverter.GetBytes(value);
        if (BitConverter.IsLittleEndian) Array.Reverse(bytes);
        writer.Write(bytes);
    }

    /// <summary>
    /// 写入大端序UInt32
    /// </summary>
    public static void WriteUInt32BigEndian(this BinaryWriter writer, uint value)
    {
        var bytes = BitConverter.GetBytes(value);
        if (BitConverter.IsLittleEndian) Array.Reverse(bytes);
        writer.Write(bytes);
    }
}
